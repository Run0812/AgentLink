{
  "name": "agentlink",
  "version": "1.0.0",
  "description": "Obsidian plugin to link with local AI agents",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "npm run lint && npm run test && node esbuild.config.mjs production",
    "build:quick": "node esbuild.config.mjs production",
    "sync:dev": "powershell -ExecutionPolicy Bypass -File ./sync-dev.ps1",
    "publish:dev": "npm run build:quick && npm run sync:dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -noEmit -skipLibCheck",
    "clean": "node -e \"require('fs').rmSync('build', {recursive: true, force: true})\"",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "ai",
    "agent",
    "claude",
    "kimi",
    "codex",
    "opencode"
  ],
  "author": "Run0812",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@emnapi/core": "^1.9.2",
    "@emnapi/runtime": "^1.9.2",
    "@types/node": "^20.19.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.27.0",
    "obsidian": "latest",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.18.1",
    "preact": "^10.26.9",
    "zod": "^4.3.6"
  }
}
